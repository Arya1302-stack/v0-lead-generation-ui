# FastAPI base URL used by the Next.js /api/scrape proxy (browser calls /api/scrape; Vercel forwards here).
# Local: run `python main.py` in /backend, then:
SCRAPE_BACKEND_URL=http://127.0.0.1:8000

# Vercel / production (Railway example — include https://, or omit the scheme and https is assumed):
# SCRAPE_BACKEND_URL=https://v0-lead-generation-ui-production.up.railway.app
# NEXT_PUBLIC_SCRAPE_API_URL=https://v0-lead-generation-ui-production.up.railway.app
# Either variable works for the server proxy; you do not need both.

# Optional FastAPI CORS (comma-separated origins) when the browser talks to FastAPI directly:
# CORS_ORIGINS=https://your-app.vercel.app,http://localhost:3000
