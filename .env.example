# FastAPI base URL used by the Next.js /api/scrape proxy (server-side only).
# Local: run `python main.py` in /backend, then:
SCRAPE_BACKEND_URL=http://127.0.0.1:8000

# Vercel / production: your public API, e.g. Railway, Render, Fly.io, or a second Vercel project:
# SCRAPE_BACKEND_URL=https://your-fastapi-host.example.com

# Optional: skip the proxy and call the API directly from the browser (then configure CORS on FastAPI via CORS_ORIGINS).
# NEXT_PUBLIC_SCRAPE_API_URL=https://your-fastapi-host.example.com

# Optional FastAPI CORS (comma-separated origins) when the browser talks to FastAPI directly:
# CORS_ORIGINS=https://your-app.vercel.app,http://localhost:3000
